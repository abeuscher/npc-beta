{
    "name": "nonprofitcrm/nonprofitcrm",
    "description": "Open source CRM and CMS platform for nonprofit organizations. Built on Laravel, Twill, and Filament PHP.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.2",
        "filament/spatie-laravel-media-library-plugin": "^3.0",
        "laravel/cashier": "^15.4",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.27",
        "mailchimp/marketing": "^3.0",
        "predis/predis": "^2.2",
        "quickbooks/v3-php-sdk": "^6.2",
        "resend/resend-php": "^1.1",
        "scssphp/scssphp": "^2.1",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-medialibrary": "^11.7",
        "spatie/laravel-permission": "^6.7",
        "spatie/laravel-schemaless-attributes": "^2.5",
        "spatie/laravel-sluggable": "^3.6",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.24",
        "laravel/pint": "^1.16",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^2.35",
        "pestphp/pest-plugin-laravel": "^2.4"
    },
    "autoload": {
        "files": [
            "app/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
