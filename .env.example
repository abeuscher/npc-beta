##
## NonProfitCRM — Environment Configuration
## Copy this file to .env and fill in your values.
## Never commit .env to version control.
##

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
APP_NAME="NonProfitCRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ─────────────────────────────────────────
# DATABASE — PostgreSQL required
# ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nonprofitcrm
DB_USERNAME=postgres
DB_PASSWORD=

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────
# QUEUE
# ─────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─────────────────────────────────────────
# SESSION / CACHE
# ─────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
CACHE_STORE=redis
CACHE_PREFIX=

# ─────────────────────────────────────────
# BROADCASTING (Soketi / Pusher compatible)
# ─────────────────────────────────────────
BROADCAST_DRIVER=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────
# MAILCHIMP
# ─────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# ─────────────────────────────────────────
# QUICKBOOKS
# ─────────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=
QB_ENVIRONMENT=sandbox

# ─────────────────────────────────────────
# ADMIN USER (used by DatabaseSeeder)
# ─────────────────────────────────────────
ADMIN_NAME="Admin"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─────────────────────────────────────────
# THEME
# ─────────────────────────────────────────
THEME_PICO=false

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
