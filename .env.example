##
## NonProfitCRM — Environment Configuration
## Copy this file to .env and fill in your values.
## Never commit .env to version control.
##
## Two provisioning paradigms:
##   • Standalone / self-host — this file IS the configuration contract. Fill in
##     the values below for your install.
##   • Fleet-Manager-managed node — the `.env` is a provisioning artifact that
##     Fleet Manager generates; it is not hand-maintained. This example stays the
##     reference for what the app reads.
##
## Integration API credentials (Stripe, Mailchimp, Resend email, QuickBooks) are
## entered in the admin Control Panel (Settings), NOT in this file — see the
## INTEGRATIONS note below. Every key here is read by the app's config layer;
## vars the app no longer reads (legacy broadcasting scaffold, env-based payment
## keys) have been removed.
##

# ─────────────────────────────────────────
# DEPLOYMENT
# ─────────────────────────────────────────
# Your GitHub username or organisation — used to pull images from GHCR.
# Example: GHCR_OWNER=myusername
GHCR_OWNER=

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
APP_NAME="NonProfitCRM"
APP_ENV=local
APP_KEY=
# SECURITY: APP_DEBUG must be false in production — debug pages leak stack traces
# carrying DB credentials and secrets. This example ships true for local dev; a
# production node MUST set it false. As a backstop, the app force-disables debug
# whenever APP_ENV=production, so a copied example cannot ship debug to prod.
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Marketing-site instance only — exposes /docs + AEO surfaces (llms-full.txt, docs in llms.txt/sitemap).
PUBLIC_WEBSITE=false

# ─────────────────────────────────────────
# DATABASE — PostgreSQL required
# ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nonprofitcrm
DB_USERNAME=postgres
DB_PASSWORD=

# Read-only DB user for advanced mailing list filters (optional).
# If not set, the main DB credentials are used as fallback.
# See the mailing-lists help article for setup instructions.
DB_READONLY_USERNAME=
DB_READONLY_PASSWORD=

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────
# QUEUE
# ─────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─────────────────────────────────────────
# SESSION / CACHE
# ─────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# HTTPS-only session cookie. Left unset, it defaults ON for every environment
# except local/dev/testing, so an HTTPS production or demo node is secure by
# default. Set it explicitly only to override (e.g. an HTTP-only internal box).
# SESSION_SECURE_COOKIE=true

# ─────────────────────────────────────────
# CONTENT SECURITY POLICY — allowed external hosts
# ─────────────────────────────────────────
# The public site enforces a strict CSP. To let a code snippet load a third
# party (Google Tag Manager / Analytics, a chat widget, external fonts/maps),
# add its host in the admin: Settings → Site → Allowed External Hosts. These env
# vars are an optional fleet-wide floor for the same lists (comma-separated
# hosts); the admin values are merged on top. Leave unset to ship the strict
# default.
# SECURITY_CSP_SCRIPT_SRC_EXTRA=
# SECURITY_CSP_CONNECT_SRC_EXTRA=
# SECURITY_CSP_IMG_SRC_EXTRA=
# SECURITY_CSP_FRAME_SRC_EXTRA=

# ─────────────────────────────────────────
# FLEET MANAGER — app-layer gate (contract v2.7.0)
# ─────────────────────────────────────────
# Second, independent lock behind the nginx mTLS termination on the five FM
# /api/* endpoints. Fleet Manager sends this per-install shared secret as the
# `X-Fleet-Gate-Key` header; the app checks it constant-time. NOT derived from
# the client cert, so it survives an nginx misconfig the mTLS `if` would not.
# Leave UNSET and the gate is inert (mTLS is the only lock — the default, and
# what every node ships with). Fleet Manager provisions a unique-per-install
# value over its config-push channel to turn the second lock on; one secret per
# install, never shared. Rotate like the cert. Generate e.g. `openssl rand -hex 32`.
# FLEET_GATE_SECRET=

CACHE_STORE=redis
CACHE_PREFIX=

# ─────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────
# Sane bootstrap defaults (log mailer). The live mailer + from-address are
# configured in the admin Control Panel (Mail Settings) and override these.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# INTEGRATIONS — entered in the admin Control Panel, not here
# ─────────────────────────────────────────
# Stripe (payments), Mailchimp (list sync), and Resend (transactional email)
# credentials are entered in the admin UI (Settings → Finance / Mail / CMS) and
# stored in the database; the app reads them from there, so there are no env
# vars for them. QuickBooks client id/secret are likewise entered in the admin
# UI; only the QuickBooks environment toggle remains an env var:
QB_ENVIRONMENT=sandbox

# ─────────────────────────────────────────
# ADMIN USER (used by DatabaseSeeder)
# ─────────────────────────────────────────
ADMIN_NAME="Admin"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─────────────────────────────────────────
# IMPORTER
# ─────────────────────────────────────────
# WARNING: FOR DEVELOPER USE ONLY. Setting this to true disables ALL PII / sensitive
# data detection in the CSV importer (credit cards, SSNs, routing numbers, etc.).
# Never set this to true in a production environment.
IMPORTER_SKIP_PII_CHECK=false

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────
# BUILD SERVER — public widget asset pipeline
# ─────────────────────────────────────────
BUILD_SERVER_URL=
BUILD_SERVER_API_KEY=

# ─────────────────────────────────────────
# BACKUPS — DigitalOcean Spaces (per-install bucket)
# ─────────────────────────────────────────
# Local dev defaults BACKUP_DISKS=local; production sets BACKUP_DISKS=spaces.
# Multi-disk targets supported via comma-separated list (e.g. "local,spaces").
BACKUP_DISKS=local

# Per-install Spaces credentials (one bucket per install; bucket-scoped key).
# See docs/app-reference.md "Backups" section for setup procedure.
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=
SPACES_REGION=
SPACES_ENDPOINT=
