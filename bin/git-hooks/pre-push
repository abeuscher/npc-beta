#!/usr/bin/env bash
# Pre-push hook: enforces the project-wide push policy from CLAUDE.md.
# Forbids pushes targeting main/master and any non-fast-forward (force) push.
#
# Activation (one-time per clone, user runs):
#   git config core.hooksPath bin/git-hooks
#
# Receives on stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
# (one line per ref being pushed). Args: <remote_name> <remote_url>.

set -euo pipefail

zero='0000000000000000000000000000000000000000'
exit_code=0

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      echo "pre-push: refusing to push to ${remote_ref}." >&2
      echo "  main/master is protected — open a PR instead." >&2
      exit_code=1
      continue
      ;;
  esac

  if [[ "$remote_sha" != "$zero" && "$local_sha" != "$zero" ]]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      echo "pre-push: refusing non-fast-forward push to ${remote_ref}." >&2
      echo "  force-push is forbidden — investigate the divergence instead." >&2
      exit_code=1
      continue
    fi
  fi
done

exit $exit_code
