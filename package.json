{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build-styles": "docker compose exec app php artisan build:public",
        "generate-thumbnails": "NODE_PATH=\"$(npm root -g)\" node scripts/generate-thumbnails.js --no-presets",
        "generate-presets": "NODE_PATH=\"$(npm root -g)\" node scripts/generate-thumbnails.js --no-static",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:stress": "playwright test --project=stress",
        "test:e2e:on-demand": "playwright test --project=on-demand",
        "test:e2e:show-report": "playwright show-report",
        "e2e:up": "docker compose -p nonprofitcrm_e2e -f docker-compose.e2e.yml up -d && docker compose -p nonprofitcrm_e2e -f docker-compose.e2e.yml exec -T app php artisan config:clear",
        "e2e:down": "docker compose -p nonprofitcrm_e2e -f docker-compose.e2e.yml down -v",
        "test:e2e:isolated": "E2E_COMPOSE_PROJECT=nonprofitcrm_e2e E2E_COMPOSE_FILES=docker-compose.e2e.yml E2E_DB_PORT=5442 APP_URL=http://localhost:8090 playwright test"
    },
    "devDependencies": {
        "@playwright/test": "1.49.1",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@types/node": "22.10.5",
        "@types/pg": "8.11.10",
        "@vitejs/plugin-vue": "^6.0.5",
        "autoprefixer": "^10.4",
        "cssnano": "^7.0",
        "dotenv": "16.4.7",
        "laravel-vite-plugin": "^1.0",
        "lucide-static": "^1.7.0",
        "pg": "8.13.1",
        "sass": "^1.70",
        "tailwindcss": "^3.4.19",
        "vite": "^5.0"
    },
    "dependencies": {
        "@vueuse/core": "^14.2.1",
        "alpinejs": "^3.0",
        "chart.js": "^4.5.1",
        "jcalendar.js": "^2.12.6",
        "modern-normalize": "^3.0.1",
        "pinia": "^3.0.4",
        "swiper": "^12.1.3",
        "vue": "^3.5.32",
        "vuedraggable": "^4.1.0"
    }
}
